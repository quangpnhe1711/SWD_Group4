@model IReadOnlyList<SWD_Group4.BusinessLogic.DTO.SellerListItemDto>
@{
    ViewData["Title"] = "Seller List";
    var message = ViewBag.Message as string;

    string Mask(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return "";
        var s = raw.Trim();
        if (s.Length <= 4) return new string('*', s.Length);
        return new string('*', s.Length - 4) + s[^4..];
    }
}

<h2>Seller List</h2>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info">@message</div>
}

<p class="text-muted">
    Showing users with Role = <code>Seller</code> or any KYC fields filled on <code>User</code>.
</p>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>UserId</th>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>URL</th>
            <th>Citizen ID</th>
            <th>Bank Account</th>
            <th>Bank Name</th>
            <th>Status</th>
            <th>Suspended Until</th>
            <th>Latest Verify</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || Model.Count == 0)
        {
            <tr><td colspan="12" class="text-center">No seller users found.</td></tr>
        }
        else
        {
            foreach (var u in Model)
            {
                <tr>
                    <td>@u.UserId</td>
                    <td>@(u.Name ?? "")</td>
                    <td>@(u.Email ?? "")</td>
                    <td>@(u.Role ?? "")</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(u.Url))
                        {
                            <a href="@u.Url" target="_blank">@u.Url</a>
                        }
                    </td>
                    <td>
                        <span class="sensitive-value" data-masked="@Mask(u.CitizenId)" data-full="@(u.CitizenId ?? "")">@Mask(u.CitizenId)</span>
                    </td>
                    <td>
                        <span class="sensitive-value" data-masked="@Mask(u.BankAccount)" data-full="@(u.BankAccount ?? "")">@Mask(u.BankAccount)</span>
                    </td>
                    <td>@(u.BankName ?? "")</td>
                    <td>@(u.Status ?? "")</td>
                    <td>
                        @if (u.Status == "Suspended" && u.SuspensionEndAt != null && u.SuspensionEndAt > DateTime.Now)
                        {
                            <span class="badge bg-danger">@u.SuspensionEndAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
                        }
                        else if (u.Status == "Suspended" && u.SuspensionEndAt != null)
                        {
                            <span class="badge bg-secondary">Expired</span>
                        }
                        else if (u.Status == "Suspended")
                        {
                            <span class="badge bg-danger">Permanent</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(u.LatestRequestStatus))
                        {
                            <div><strong>@u.LatestRequestStatus</strong></div>
                            <div class="text-muted" style="font-size: 0.9em;">@(u.LatestRequestCreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "")</div>
                        }
                    </td>
                    <td class="d-flex flex-column gap-2" style="min-width: 240px;">
                        @if (u.LatestRequestId != null)
                        {
                            <a class="btn btn-sm btn-outline-primary" asp-action="getDetail" asp-route-requestId="@u.LatestRequestId">View latest request</a>
                        }

                        <button type="button"
                                class="btn btn-sm btn-warning btn-suspend"
                                data-bs-toggle="modal"
                                data-bs-target="#suspendModal"
                                data-user-id="@u.UserId"
                                data-user-email="@(u.Email ?? "")">
                            Suspend
                        </button>

                        <form asp-action="unsuspendSeller" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@u.UserId" />
                            @if (u.Status == "Suspended")
                            {
                                <button type="submit" class="btn btn-sm btn-outline-success">Unsuspend</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="User is not suspended">Unsuspend</button>
                            }
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<a asp-action="viewPendingRequests" class="btn btn-link">Back to pending list</a>

<!-- Suspend modal (shared) -->
<div class="modal fade" id="suspendModal" tabindex="-1" aria-labelledby="suspendModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="suspendModalLabel">Suspend seller</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="suspendSeller" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="SuspendUserId" name="UserId" />

                    <div class="mb-2 text-muted" id="SuspendUserMeta"></div>

                    <div class="mb-3">
                        <label for="SuspendReason" class="form-label">Reason</label>
                        <textarea id="SuspendReason" name="Reason" class="form-control" rows="3" placeholder="Reason (min 20 characters)" required minlength="20"></textarea>
                        <div class="form-text">Business rule BR-OPS-04: minimum 20 characters.</div>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6">
                            <label for="SuspendDurationType" class="form-label">Duration</label>
                            <select id="SuspendDurationType" name="DurationType" class="form-select">
                                <option value="OneWeek" selected>1 week</option>
                                <option value="OneMonth">1 month</option>
                                <option value="OneYear">1 year</option>
                                <option value="Permanent">Permanent</option>
                            </select>
                            <div class="form-text">BE will calculate suspension_end_at automatically.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Confirm suspend</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .sensitive-value { cursor: pointer; user-select: none; }
    </style>
    <script>
        (function () {
            function toggle(el) {
                if (!el) return;
                var showing = el.getAttribute('data-showing') === 'true';
                if (showing) {
                    el.textContent = el.getAttribute('data-masked') || '';
                    el.setAttribute('data-showing', 'false');
                } else {
                    el.textContent = el.getAttribute('data-full') || '';
                    el.setAttribute('data-showing', 'true');
                }
            }


            document.querySelectorAll('.sensitive-value').forEach(function (el) {
                el.addEventListener('click', function () { toggle(el); });
            });

            var durationSel = document.getElementById('SuspendDurationType');

            document.querySelectorAll('.btn-suspend').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var userId = btn.getAttribute('data-user-id') || '';
                    var email = btn.getAttribute('data-user-email') || '';

                    var idInput = document.getElementById('SuspendUserId');
                    var reasonInput = document.getElementById('SuspendReason');
                    var meta = document.getElementById('SuspendUserMeta');

                    if (idInput) idInput.value = userId;
                    if (reasonInput) reasonInput.value = '';
                    if (durationSel) durationSel.value = 'OneWeek';
                    if (meta) meta.textContent = 'UserId: ' + userId + (email ? ' | Email: ' + email : '');

                });
            });
        })();
    </script>
}
